# Server Config
PORT=5005
NODE_ENV=production

# MongoDB Atlas (replace with your connection string)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/affiliate_tracking?retryWrites=true&w=majority

# JWT Secret (use a long, random string in production)
JWT_SECRET=replace_with_a_very_long_random_secret_key_here

# Frontend URL (your Vercel deployment URL)
FRONTEND_URL=https://your-app-name.vercel.app
